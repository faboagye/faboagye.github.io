installed.packages("RANN")
library(RANN)
set.seed(123)
nx <- 120   # width  (high resolution)
ny <- 120   # height
n_spots <- nx * ny
coords <- expand.grid(
x = 1:nx,
y = 1:ny
)
# Circular domain in the center = Domain 1 (tumor-like)
cx <- nx/2
cy <- ny/2
r1 <- 30
coords$domain <- ifelse(
sqrt((coords$x - cx)^2 + (coords$y - cy)^2) < r1,
1,
2
)
# Create an outer ring domain = Domain 3
coords$domain[sqrt((coords$x - cx)^2 + (coords$y - cy)^2) > r1 &
sqrt((coords$x - cx)^2 + (coords$y - cy)^2) < r1 + 15] <- 3
n_genes <- 100
# Base expression by domain
mu <- matrix(0, 3, n_genes)
mu[1,] <- rnorm(n_genes, 2, 0.5)   # domain 1 high activity
mu[2,] <- rnorm(n_genes, 0, 0.5)   # domain 2 baseline
mu[3,] <- rnorm(n_genes, 1, 0.5)   # domain 3 medium
# Generate expression matrix
expr <- matrix(0, nrow = n_spots, ncol = n_genes)
for (i in 1:n_spots) {
d <- coords$domain[i]
expr[i,] <- mu[d,] + rnorm(n_genes, 0, 0.3)
}
# Two random augmentations (cropping + gaussian noise)
augment <- function(mat) {
mat + matrix(rnorm(length(mat), 0, 0.1), nrow(mat))
}
expr_a <- augment(expr)
expr_b <- augment(expr)
# Cosine similarity loss
cos_sim <- function(a, b) sum(a*b) / (sqrt(sum(a^2)) * sqrt(sum(b^2)))
# Learn low-dimensional embedding
latent_dim <- 10
W <- matrix(rnorm(n_genes * latent_dim, 0, 0.1), n_genes, latent_dim)
# Simple gradient descent contrastive objective
lr <- 0.001
epochs <- 50
for (ep in 1:epochs) {
Z1 <- expr_a %*% W
Z2 <- expr_b %*% W
sim <- rowSums(Z1 * Z2)
loss <- -mean(sim)
grad <- -(t(expr_a) %*% Z2 + t(expr_b) %*% Z1) / n_spots
W <- W - lr * grad
}
# Final embedding
embedding <- expr %*% W
k <- 3
cl <- kmeans(embedding, centers = k)$cluster
coords$cluster <- cl
p_true <- ggplot(coords, aes(x, y, fill = factor(domain))) +
geom_raster() +
coord_fixed() +
scale_fill_manual(values = c("red", "white", "blue")) +
labs(title = "True Spatial Domains (Simulated Tissue)") +
theme_void()
p_learned <- ggplot(coords, aes(x, y, fill = factor(cluster))) +
geom_raster() +
coord_fixed() +
scale_fill_manual(values = c("#1f78b4","#33a02c","#e31a1c")) +
labs(title = "CSSL-Learned Spatial Domains from Multi-Omics Features") +
theme_void()
p_true
p_learned
