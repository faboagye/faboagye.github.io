library(ggplot2)
library(dplyr)
library(tidyr)
set.seed(123)
## ---------------------------
## 1. Simulation settings
## ---------------------------
nx  <- 64        # x dimension (voxels)
ny  <- 64        # y dimension (voxels)
nT  <- 120       # number of time points (TRs)
TR  <- 2         # repetition time (seconds) - just for reference
# Simple block design: 20 on, 20 off, repeated
block_len <- 20
design_vec <- rep(c(rep(0, block_len), rep(1, block_len)), length.out = nT)
## ---------------------------
## 2. Simple HRF + convolved design
## ---------------------------
# Simple HRF (not a full canonical HRF, but good enough for demonstration)
t_hrf <- seq(0, 30, by = TR)
hrf   <- t_hrf^8 * exp(-t_hrf / 4)
hrf   <- hrf / max(hrf)  # normalize
# Convolve design with HRF
conv_full <- convolve(design_vec, rev(hrf), type = "open")
conv_full <- conv_full[1:nT]  # match length
bold_regressor <- scale(conv_full)  # standardize for numerical stability
## ---------------------------
## 3. Ground truth activation map (2D)
## ---------------------------
# Create coordinates
coords <- expand.grid(
x = 1:nx,
y = 1:ny
)
# Define a circular "activated" region in the center
cx <- nx / 2
cy <- ny / 2
radius <- 10
coords <- coords %>%
mutate(
dist_center = sqrt((x - cx)^2 + (y - cy)^2),
beta_true   = ifelse(dist_center <= radius, 1.0, 0.0),  # activation amplitude
baseline    = 100                                        # arbitrary baseline signal
)
# Visualize ground truth beta
ggplot(coords, aes(x, y, fill = beta_true)) +
geom_raster() +
coord_fixed() +
scale_fill_viridis_c(option = "C", name = "True beta") +
labs(
title = "Ground Truth Activation Map (Beta)",
x = "Voxel (x)", y = "Voxel (y)"
) +
theme_bw()
library(ggplot2)
library(dplyr)
install.packages("pracma")
