library(AnalyzeFMRI)
library(oro.nifti)
library(neuRosim)
set.seed(123)
dims <- c(80, 80, 60)
brain <- array(rnorm(prod(dims), 0, 1), dim = dims)
# Smooth to create MRI-like structure
brain_smooth <- GaussSmoothArray(
brain,
voxdim = c(1,1,1),
ksize = 9
)
generate_blob <- function(dims, center, sd = 5, amplitude = 5) {
arr <- array(0, dim = dims)
for (x in 1:dims[1]) {
for (y in 1:dims[2]) {
for (z in 1:dims[3]) {
d2 <- (x-center[1])^2 + (y-center[2])^2 + (z-center[3])^2
arr[x,y,z] <- amplitude * exp(-d2 / (2*sd^2))
}
}
}
return(arr)
}
# Tumor-like sphere
act1 <- generate_blob(dims, center = c(40, 40, 30), sd = 6, amplitude = 6)
# Cortical ellipsoid-like region
act2 <- generate_blob(dims, center = c(25, 60, 25), sd = 10, amplitude = 4)
# Irregular cluster (offset blobs)
act3 <- generate_blob(dims, center = c(60, 20, 20), sd = 4, amplitude = 5) +
generate_blob(dims, center = c(55, 25, 22), sd = 3, amplitude = 3)
final_brain <- brain_smooth + act1 + act2 + act3
nifti_brain <- nifti(final_brain)
par(mfrow = c(2,2))
image(nifti_brain, z = 15, main = "Slice 15")
image(nifti_brain, z = 25, main = "Slice 25")
image(nifti_brain, z = 35, main = "Slice 35")
image(nifti_brain, z = 45, main = "Slice 45")
## -------------------------------------------------------------
##  High-quality simulated brain + nice visualizations in R
## -------------------------------------------------------------
library(oro.nifti)
library(neurobase)   # for mosaic / ortho2
library(RNifti)
set.seed(123)
## 1. Dimensions and helper grid
dims <- c(80, 80, 60)  # fairly high resolution
nx <- dims[1]; ny <- dims[2]; nz <- dims[3]
x <- array(rep(1:nx, each = ny * nz), dim = dims)
y <- array(rep(rep(1:ny, each = nz), times = nx), dim = dims)
z <- array(rep(1:nz, times = nx * ny), dim = dims)
## 2. Smooth anatomical background (Gaussian random field)
noise <- array(rnorm(prod(dims), mean = 0, sd = 1), dim = dims)
# simple 3D Gaussian smoothing via local averaging
smooth3d <- function(vol, k = 3L) {
pad <- floor(k / 2)
vol_pad <- array(0, dim = dims + 2 * pad)
vol_pad[(pad+1):(pad+nx),
(pad+1):(pad+ny),
(pad+1):(pad+nz)] <- vol
out <- array(0, dim = dims)
for (i in 1:nx) {
for (j in 1:ny) {
for (kz in 1:nz) {
block <- vol_pad[i:(i+2*pad), j:(j+2*pad), kz:(kz+2*pad)]
out[i,j,kz] <- mean(block)
}
}
}
out
}
anat <- smooth3d(noise, k = 5L)   # anatomical-like background
anat <- scale(anat)               # normalize
# Helper to build a sphere
make_sphere <- function(center, radius, value = 1) {
mask <- ((x - center[1])^2 +
(y - center[2])^2 +
(z - center[3])^2) <= radius^2
out <- array(0, dim = dims)
out[mask] <- value
out
}
# Helper to build an ellipsoid
make_ellipsoid <- function(center, radii, value = 1) {
mask <- ((x - center[1])^2 / radii[1]^2 +
(y - center[2])^2 / radii[2]^2 +
(z - center[3])^2 / radii[3]^2) <= 1
out <- array(0, dim = dims)
out[mask] <- value
out
}
# Helper rectangular slab
make_box <- function(xrng, yrng, zrng, value = 1) {
mask <- x >= xrng[1] & x <= xrng[2] &
y >= yrng[1] & y <= yrng[2] &
z >= zrng[1] & z <= zrng[2]
out <- array(0, dim = dims)
out[mask] <- value
out
}
act1 <- make_sphere(center = c(40, 40, 30), radius = 7,  value = 3)              # tumor-like
act2 <- make_ellipsoid(center = c(25, 60, 25), radii = c(10, 4, 6), value = 2.5) # cortical strip
act3 <- make_box(xrng = c(55, 65), yrng = c(15, 25), zrng = c(18, 26), value = 2) # lesion-like
activation <- act1 + act2 + act3
## 4. Combine anatomy + activation into final “brain signal”
brain <- anat + activation
