library(oro.nifti)
library(neurobase)
library(AnalyzeFMRI)
set.seed(123)
dims <- c(80, 80, 60)
nx <- dims[1]; ny <- dims[2]; nz <- dims[3]
x <- array(rep(1:nx, each = ny * nz), dim = dims)
y <- array(rep(rep(1:ny, each = nz), times = nx), dim = dims)
z <- array(rep(1:nz, times = nx * ny), dim = dims)
noise <- array(rnorm(prod(dims), 0, 1), dim = dims)
# Stable smoothing (dimensions preserved)
anat <- GaussSmoothArray(
noise,
voxdim = c(1,1,1),
ksize = 9
)
anat <- scale(anat)                 # normalize
anat <- array(anat, dim=dims)        # ensure exact dims
make_sphere <- function(center, radius, value=1) {
mask <- ((x-center[1])^2 + (y-center[2])^2 + (z-center[3])^2) <= radius^2
out <- array(0, dim=dims)
out[mask] <- value
out
}
make_ellipsoid <- function(center, radii, value=1) {
mask <- ((x-center[1])^2 / radii[1]^2 +
(y-center[2])^2 / radii[2]^2 +
(z-center[3])^2 / radii[3]^2) <= 1
out <- array(0, dim=dims)
out[mask] <- value
out
}
make_box <- function(xrng, yrng, zrng, value=1) {
mask <- x>=xrng[1] & x<=xrng[2] &
y>=yrng[1] & y<=yrng[2] &
z>=zrng[1] & z<=zrng[2]
out <- array(0, dim=dims)
out[mask] <- value
out
}
# Three different regions
act1 <- make_sphere(center=c(40,40,30), radius=7,  value=3)
act2 <- make_ellipsoid(center=c(25,60,25), radii=c(10,4,6), value=2.5)
act3 <- make_box(xrng=c(55,65), yrng=c(15,25), zrng=c(18,26), value=2)
activation <- act1 + act2 + act3
brain <- anat + activation
anat_img  <- nifti(anat)
act_img   <- nifti(activation)
brain_img <- nifti(brain)
### 6A. Slice mosaic (custom function)
mosaic_view <- function(img, slices, col=gray.colors(256)) {
par(mfrow = c(3, 3), mar=c(1,1,1,1))
for (z in slices) {
image(img[,,z], col=col, axes=FALSE, main=paste("z =", z))
}
par(mfrow=c(1,1))
}
slices <- seq(5, 55, by = 5)
# Anatomy mosaic
mosaic_view(anat, slices, col = gray.colors(256))
# Activation mosaic
mosaic_view(activation, slices, col = hotmetal(256))
### 6B. Orthographic activation overlay
ortho2(
anat_img,
y = act_img,
col = gray.colors(256),
col.y = hotmetal(256),
main = "Simulated Brain Activations (Orthographic View)"
)
