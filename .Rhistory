y>=yrng[1] & y<=yrng[2] &
z>=zrng[1] & z<=zrng[2]
out <- array(0, dim=dims)
out[mask] <- value
out
}
# Three different regions
act1 <- make_sphere(center=c(40,40,30), radius=7,  value=3)
act2 <- make_ellipsoid(center=c(25,60,25), radii=c(10,4,6), value=2.5)
