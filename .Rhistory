"RNifti",             # Fast NIfTI I/O
"neurobase",          # General neuroimaging utilities
# ---- Simulation & Spatial Brain Modeling ----
"neuRosim",           # High-quality fMRI & brain simulation
"AnalyzeFMRI",        # Spatial smoothing, Gaussian random fields
"fmri",               # Classic fMRI models and deconvolution
# ---- Structural & Multimodal Analysis ----
"ANTsRCore",          # Core ANTs tools
"ANTsR",              # Registration, segmentation, denoising
# ---- Surface Tools (FreeSurfer-compatible) ----
"freesurferformats",  # Read/write FreeSurfer surfaces and morphometry
# ---- Graph & Connectomics ----
"brainGraph",         # Structural/functional brain networks
"igraph",             # Graph theory engine
# ---- Wavelet & Optimization Tools ----
"waveslim",           # Wavelets used in MRI compression
"dipsaus"             # High-performance neuroimaging helpers
))
